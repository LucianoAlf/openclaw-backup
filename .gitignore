# Credenciais e dados sensíveis
.env
*.pem
*.key
*.json.secret

# Arquivos de sessão e cache do OpenClaw
.openclaw/

# Memória diária (pode conter contexto privado)
memory/

# Mas força a inclusão da pasta governanca (CEO Quest)
!memory/governanca/
!memory/governanca/**

# Arquivos temporários
*.tmp
*.log
